{
  "app": {
    "identifier": "io.longhill.pdf",
    "version": "1.0.0",
    "title": "Stirling PDF",
    "icon": "icon/stirling.png",
    "url": {
      "pdf": "https://pdf.longhill.io/"
    },
    "use_favicon": true,
    "tray_icon": false,
    "notifications": true,
    "close_to_tray": false,
    "reuse_instance": true
  },
  "window": {
    "width": 1280,
    "height": 720,
    "resizable": true,
    "title_bar": true,
    "fullscreen": false,
    "maximized": false,
    "always_on_top": false,
    "drag_drop": true,
    "allow_new": true
  },
  "webview": {
    "incognito": true,
    "mailto_url_template": "",
    "args": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --disable-blink-features=AutomationControlled --enable-features=SharedArrayBuffer --enable-unsafe-webgpu --force-dark-mode"
  },
  "internal_url": {
    "prefixes": [],
    "regexes": []
  }
}
